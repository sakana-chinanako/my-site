---
interface Props { items: { label: string; href?: string }[] }
const { items } = Astro.props;
---
<nav class="mb-3 flex items-center space-x-1.5 text-sm text-gray-500 dark:text-gray-400" aria-label="面包屑导航">
  {items.map((item, index) => (
    <>
      {index > 0 && (
        <svg class="w-3.5 h-3.5 text-gray-300 dark:text-gray-600 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      )}
      {item.href ? (
        <a href={item.href} class="link-underline hover:text-primary-600 dark:hover:text-primary-400 transition-colors truncate">{item.label}</a>
      ) : (
        <span class="text-gray-700 dark:text-gray-200 font-medium truncate" aria-current="page">{item.label}</span>
      )}
    </>
  ))}
</nav>
