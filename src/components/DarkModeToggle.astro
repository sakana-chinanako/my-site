<button id="darkmode-toggle" class="p-2 rounded-md text-gray-500 hover:bg-gray-100 dark:text-gray-400 dark:hover:bg-gray-800 transition-colors" aria-label="切换暗色模式" title="切换暗色/亮色模式">
  <svg id="dm-sun" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" x2="12" y1="1" y2="3"/><line x1="12" x2="12" y1="21" y2="23"/><line x1="4.22" x2="5.64" y1="4.22" y2="5.64"/><line x1="18.36" x2="19.78" y1="18.36" y2="19.78"/><line x1="1" x2="3" y1="12" y2="12"/><line x1="21" x2="23" y1="12" y2="12"/><line x1="4.22" x2="5.64" y1="19.78" y2="18.36"/><line x1="18.36" x2="19.78" y1="5.64" y2="4.22"/></svg>
  <svg id="dm-moon" class="w-4 h-4 hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
</button>
<script>(function(){
var b = document.getElementById("darkmode-toggle"), s = document.getElementById("dm-sun"), m = document.getElementById("dm-moon");
if (!b) return;
function setD(d) {
  document.documentElement.classList.toggle("dark", d);
  s.classList.toggle("hidden", d);
  m.classList.toggle("hidden", !d);
  try { localStorage.setItem("theme", d ? "dark" : "light"); } catch (e) {}
}
var st = null;
try { st = localStorage.getItem("theme"); } catch (e) {}
if (st === "dark" || st === "light") setD(st === "dark");
else if (window.matchMedia("(prefers-color-scheme: dark)").matches) setD(true);
b.addEventListener("click", function() { setD(!document.documentElement.classList.contains("dark")); });
})();</script>
