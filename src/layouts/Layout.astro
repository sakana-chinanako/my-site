---
import '../styles/global.css';
import DarkModeToggle from '../components/DarkModeToggle.astro';

interface Props { title?: string; description?: string }
const { title = 'lycoris', description = '文档与图片资源管理站' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页', icon: 'home' },
  { href: '/docs', label: '文档', icon: 'files' },
  { href: '/images', label: '图片', icon: 'image' },
  { href: '/search', label: '搜索', icon: 'search' },
  { href: '/about', label: '关于', icon: 'user' },
];

const isActive = (href: string) => currentPath === href || (href !== '/' && currentPath.startsWith(href + '/'));
---
<!DOCTYPE html>
<html lang="zh-CN" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="sitemap" href="/sitemap-index.xml" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <script is:inline>(function(){
    var s = null;
    try { s = localStorage.getItem("theme"); } catch (e) {}
    if (s === "dark" || (!s && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
      document.documentElement.classList.add("dark");
    }
  })();</script>
</head>
<body class="min-h-screen flex flex-col text-slate-900 dark:text-slate-200">
  <a href="#main-content" class="sr-only focus:fixed focus:z-100 focus:top-3 focus:left-3 focus:px-4 focus:py-2 focus:bg-primary-600 focus:text-white focus:rounded-lg focus:shadow-lg focus:outline-none focus:w-auto focus:h-auto focus:overflow-visible focus:whitespace-nowrap">
    跳到内容
  </a>
  <nav class="nav-glass sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
      <a href="/" class="text-sm font-bold text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 transition-colors flex items-center gap-2">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        <span>lycoris</span>
      </a>
      <div class="hidden md:flex items-center space-x-1">
        {navItems.map(item => (
          <a href={item.href} class={isActive(item.href) ? 'px-3 py-1.5 rounded-lg text-sm font-medium bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400 transition-colors flex items-center gap-1.5' : 'px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700/50 hover:text-gray-900 dark:hover:text-white transition-colors flex items-center gap-1.5'}>
            {item.icon === 'home' && (<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>)}
            {item.icon === 'files' && (<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>)}
            {item.icon === 'image' && (<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>)}
            {item.icon === 'search' && (<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>)}
            {item.icon === 'user' && (<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>)}
            {item.label}
          </a>
        ))}
      </div>
      <div class="flex items-center gap-1">
        <DarkModeToggle />
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-slate-700/50 transition-colors" aria-label="菜单" aria-expanded="false" aria-controls="mobile-menu">
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="md:hidden overflow-hidden transition-all duration-300 ease-in-out" style="max-height: 0; opacity: 0;">
      <div class="bg-white/95 dark:bg-slate-900/95 backdrop-blur-md px-2 pt-2 pb-3 space-y-1 border-t border-gray-100 dark:border-slate-800">
        {navItems.map(item => (
          <a href={item.href} class={isActive(item.href) ? 'block px-3 py-2 rounded-lg text-sm font-medium bg-primary-50 dark:bg-primary-900/30 text-primary-700 dark:text-primary-400' : 'block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700/50'}>{item.label}</a>
        ))}
      </div>
    </div>
  </nav>
  <main id="main-content" class="flex-1 max-w-6xl w-full mx-auto px-4 py-6"><slot /></main>
  <footer class="nav-glass mt-auto">
    <div class="max-w-6xl mx-auto px-4 py-5 text-center">
      <p class="text-xs text-gray-400 dark:text-gray-500">&copy; {new Date().getFullYear()} lycoris · 个人知识库</p>
    </div>
  </footer>
  <button id="back-to-top" class="fixed bottom-6 right-6 p-2.5 rounded-full card opacity-0 translate-y-2 pointer-events-none transition-all duration-300 z-40 text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400" aria-label="回到顶部" title="回到顶部">
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m18 15-6-6-6 6"/></svg>
  </button>
  <script>// @ts-nocheck
  var btt = document.getElementById("back-to-top");
  if (btt) {
    window.addEventListener("scroll", function() {
      if (window.scrollY > 400) { btt.classList.remove("opacity-0","translate-y-2","pointer-events-none"); }
      else { btt.classList.add("opacity-0","translate-y-2","pointer-events-none"); }
    });
    btt.addEventListener("click", function() { window.scrollTo({ top: 0, behavior: "smooth" }); });
  }</script>
  <script>// @ts-nocheck
  (function(){
    var b = document.getElementById("mobile-menu-btn"), m = document.getElementById("mobile-menu");
    if (!b || !m) return;
    var o = false;
    b.addEventListener("click", function() {
      o = !o;
      if (o) { m.style.maxHeight = m.scrollHeight + "px"; m.style.opacity = "1"; }
      else { m.style.maxHeight = "0"; m.style.opacity = "0"; }
      b.setAttribute("aria-expanded", String(o));
    });
    document.addEventListener("click", function(e) {
      if (o && !m.contains(e.target) && !b.contains(e.target)) {
        o = false; m.style.maxHeight = "0"; m.style.opacity = "0";
        b.setAttribute("aria-expanded", "false");
      }
    });
  })();</script>
</body>
</html>
