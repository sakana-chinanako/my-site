---
import Layout from '../layouts/Layout.astro';
---
<Layout title="页面未找到 - lycoris">
  <div class="max-w-5xl mx-auto pt-12 text-center">
    <div class="card p-12">
      <div class="text-7xl font-bold mb-4 text-gray-200 dark:text-gray-700">404</div>
      <h1 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">页面未找到</h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">您访问的页面不存在或已被移除</p>
      <div class="flex items-center justify-center gap-3">
        <a href="/" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-primary-600 text-white text-sm hover:bg-primary-700 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          返回首页
        </a>
        <a href="/search" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-gray-300 text-sm hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>
          搜索资源
        </a>
      </div>
    </div>
  </div>
</Layout>
