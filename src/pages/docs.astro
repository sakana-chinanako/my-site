---
import Layout from '../layouts/Layout.astro';
import { loadIndex } from '../utils/index-loader.js';

const categories = [];
const ix = loadIndex();
if (ix && ix.files) {
  const df = ix.files.filter(f => f.type === 'doc');
  const cm = new Map();
  for (const f of df) {
    cm.set(f.category, (cm.get(f.category) || 0) + 1);
  }
  for (const [n, c] of cm) {
    categories.push({ name: n, count: c, path: '/docs/' + encodeURIComponent(n) });
  }
}
---
<Layout title="文档 - 资源站">
  <div class="max-w-5xl mx-auto">
    <div class="mb-4">
      <h1 class="text-xl font-semibold text-gray-900 dark:text-white">文档</h1>
    </div>
    {categories.length === 0 ? (
      <div class="text-center py-16 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700">
        <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">暂无文档分类</p>
        <p class="text-gray-300 dark:text-gray-600 text-xs mt-1">将文档放入 public/docs/ 下的对应目录</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-3">
        {categories.map(cat => (
          <a href={cat.path} class="group flex items-center justify-between p-4 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 hover:border-primary-500 dark:hover:border-primary-500 hover:shadow-sm transition-all">
            <div class="flex items-center gap-3 min-w-0">
              <svg class="w-5 h-5 text-gray-400 dark:text-gray-500 group-hover:text-primary-600 dark:group-hover:text-primary-400 shrink-0 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 20a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.9a2 2 0 0 1-1.69-.9L9.6 3.9A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13a2 2 0 0 0 2 2Z"/></svg>
              <span class="font-medium text-sm text-gray-900 dark:text-white truncate">{cat.name}</span>
            </div>
            <span class="text-xs text-gray-400 dark:text-gray-500 tabular shrink-0 ml-2">{cat.count}</span>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
