---
import path from 'path';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Toast from '../../components/Toast.astro';
import ZipDownload from '../../components/ZipDownload.astro';
import { loadIndex } from '../../utils/index-loader.js';
import { getDocColor } from '../../utils/file-utils.js';

export function getStaticPaths() {
  const ix = loadIndex();
  const paths = [];
  if (ix && ix.files) {
    const cats = [...new Set(ix.files.filter(f => f.type === 'doc').map(f => f.category))];
    for (const c of cats) paths.push({ params: { category: c } });
  }
  return paths;
}

const { category } = Astro.params;
// @ts-ignore
const ix = loadIndex();

// 白名单校验：只允许索引中存在的分类
// @ts-ignore
const validCats = new Set(ix?.files?.filter(f => f.type === 'doc').map(f => f.category) || []);
// @ts-ignore
if (!category || !validCats.has(category) || /[\\\\/]/.test(category)) {
  return new Response('Not Found', { status: 404 });
}

const files = [];
if (ix && ix.files) {
  // @ts-ignore
  const cf = ix.files.filter(f => f.type === 'doc' && f.category === category);
  for (const f of cf) {
    const e = '.' + f.ext;
    const c = getDocColor(e);
    files.push({
      name: f.name.replace(e, ''),
      fullName: f.name,
      size: f.size,
      sizeBytes: f.sizeBytes || 0,
      ext: e,
      colors: c,
      path: f.path,
      isReadable: ['.md', '.txt'].includes(e.toLowerCase())
    });
  }
}
files.sort((a, b) => a.name.localeCompare(b.name, 'zh'));
---
<Layout title={category + ' - 文档'}>
  <div class="max-w-4xl mx-auto">
    <Breadcrumb items={[{ label: '文档', href: '/docs' }, { label: category as string }]} />
    <div class="mb-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">{category} <span class="text-sm font-normal text-gray-400 dark:text-gray-500 tabular">({files.length})</span></h1>
      <div class="flex items-center gap-2">
        <button id="select-all" class="text-xs px-3 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">全选</button>
        <button id="download-zip" data-category={category} data-checkbox-selector=".select-checkbox" class="text-xs px-3 py-1.5 rounded-lg bg-primary-600 text-white hover:bg-primary-700 dark:bg-primary-600 dark:hover:bg-primary-500 transition-colors disabled:opacity-40 disabled:cursor-not-allowed" disabled>打包下载</button>
      </div>
    </div>
    {files.length === 0 ? (
      <div class="card p-8 text-center">
        <svg class="w-14 h-14 text-gray-300 dark:text-gray-600 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">暂无文件</p>
        <p class="text-gray-400 dark:text-gray-600 text-xs mt-1">将文件放入 public/docs/{category}/ 目录</p>
      </div>
    ) : (
      <div class="card overflow-hidden">
        <ul class="divide-y divide-gray-100 dark:divide-slate-700/50">
          {files.map(file => (
            <li class="group flex items-center gap-3 py-3 px-4 hover:bg-gray-50 dark:hover:bg-slate-700/30 transition-colors">
              <input type="checkbox" class="select-checkbox w-3.5 h-3.5 rounded border-gray-300 dark:border-slate-600 text-primary-600 focus:ring-primary-500 shrink-0" data-path={file.path} data-name={file.fullName} data-size={file.sizeBytes} />
              <div class={"w-8 h-8 rounded-lg flex items-center justify-center shrink-0 " + file.colors.bgClass + " " + file.colors.textClass}>
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-gray-900 dark:text-white truncate">{file.name}</p>
                <p class="text-xs text-gray-400 dark:text-gray-500 tabular">{file.size}</p>
              </div>
              <div class="flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity shrink-0">
                {file.isReadable && (
                  <a href={'/docs/' + encodeURIComponent(category as string) + '/' + encodeURIComponent(file.name)} class="p-1.5 rounded-lg hover:bg-primary-50 dark:hover:bg-primary-900/30 text-primary-600 dark:text-primary-400" title="阅读">
                    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                  </a>
                )}
                <a href={file.path} download class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-slate-600 text-gray-500 dark:text-gray-400" title="下载">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15V3"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="m7 10 5 5 5-5"/></svg>
                </a>
                <a href={file.path} target="_blank" rel="noopener noreferrer" class="p-1.5 rounded-lg hover:bg-gray-200 dark:hover:bg-slate-600 text-gray-500 dark:text-gray-400" title="新窗口打开">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                </a>
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
    <div class="mt-4">
      <a href="/docs" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 link-underline hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        返回
      </a>
    </div>
  </div>
  <Toast />
  <ZipDownload />
</Layout>
