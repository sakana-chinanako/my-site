---
import Layout from '../layouts/Layout.astro';
import { loadIndex } from '../utils/index-loader.js';

const categories = [];
const ix = loadIndex();
if (ix && ix.files) {
  const imf = ix.files.filter(f => f.type === 'image');
  const cm = new Map();
  for (const f of imf) {
    if (!cm.has(f.category)) cm.set(f.category, { count: 0, covers: [] });
    const c = cm.get(f.category);
    c.count++;
    if (c.covers.length < 4) { const p = f.path; const ld = p.lastIndexOf('.'); c.covers.push(ld > 0 ? '/thumbnails' + p.substring(0, ld) + '.webp' : p); }
  }
  for (const [n, d] of cm) {
    categories.push({ name: n, count: d.count, path: '/images/' + encodeURIComponent(n), covers: d.covers });
  }
}
---
<Layout title="图片 - lycoris">
  <div class="max-w-5xl mx-auto">
    <div class="mb-6">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">图片</h1>
    </div>
    {categories.length === 0 ? (
      <div class="card text-center py-16">
        <svg class="w-14 h-14 text-gray-300 dark:text-gray-600 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">暂无图片分类</p>
        <p class="text-gray-400 dark:text-gray-600 text-xs mt-1">将图片放入 public/images/ 下的对应目录</p>
      </div>
    ) : (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {categories.map(cat => (
          <a href={cat.path} class="card group overflow-hidden">
            <div class="aspect-4/3 bg-gray-100 dark:bg-slate-700 relative overflow-hidden grid grid-cols-2 grid-rows-2 gap-px">
              {cat.covers.map(cover => (<img src={cover} alt="" class="w-full h-full object-cover" loading="lazy" />))}
              {Array.from({ length: 4 - cat.covers.length }).map(() => (
                <div class="w-full h-full bg-gray-200 dark:bg-slate-600 flex items-center justify-center">
                  <svg class="w-5 h-5 text-gray-300 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </div>
              ))}
              <div class="absolute top-2 right-2 bg-black/60 text-white text-xs font-medium px-2 py-0.5 rounded-full backdrop-blur-sm tabular">{cat.count}</div>
            </div>
            <div class="p-3">
              <h2 class="font-medium text-sm text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">{cat.name}</h2>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Layout>
