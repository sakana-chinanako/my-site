---
import path from 'path';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Toast from '../../components/Toast.astro';
import ZipDownload from '../../components/ZipDownload.astro';
import { loadIndex } from '../../utils/index-loader.js';

export function getStaticPaths() {
  const ix = loadIndex();
  const paths = [];
  if (ix && ix.files) {
    const cats = [...new Set(ix.files.filter(f => f.type === 'image').map(f => f.category))];
    for (const c of cats) paths.push({ params: { category: c } });
  }
  return paths;
}

const { category } = Astro.params;
// @ts-ignore
const ix = loadIndex();
const PER_PAGE = 40;

// 校验分类
// @ts-ignore
const validCats = new Set(ix?.files?.filter(f => f.type === 'image').map(f => f.category) || []);
// @ts-ignore
if (!category || !validCats.has(category) || /[\\\\/]/.test(category)) {
  return new Response('Not Found', { status: 404 });
}

const page = parseInt(Astro.url.searchParams.get('page') || '1') || 1;

const allImages = [];
if (ix && ix.files) {
  // @ts-ignore
  const cf = ix.files.filter(f => f.type === 'image' && f.category === category);
  for (const f of cf) {
    const e = '.' + f.ext;
    let m = f.meta || {};
    // 缩略图路径: /thumbnails/images/...
    const p = f.path;
    const lastDot = p.lastIndexOf('.');
    const thumbPath = lastDot > 0 ? '/thumbnails' + p.substring(0, lastDot) + '.webp' : p;
    allImages.push({
      name: f.name.replace(e, ''),
      fullName: f.name,
      size: f.size,
      sizeBytes: f.sizeBytes || 0,
      path: p,
      thumbPath: thumbPath,
      meta: m
    });
  }
}
allImages.sort((a, b) => a.name.localeCompare(b.name, 'zh'));

const totalPages = Math.ceil(allImages.length / PER_PAGE) || 1;
const start = (Math.min(page, totalPages) - 1) * PER_PAGE;
const images = allImages.slice(start, start + PER_PAGE);
---
<Layout title={category + ' - 图片'}>
  <div class="max-w-6xl mx-auto">
    <Breadcrumb items={[{ label: '图片', href: '/images' }, { label: category as string }]} />
    <div class="mb-4 flex items-center justify-between">
      <h1 class="text-2xl font-bold tracking-tight text-gray-900 dark:text-white">{category} <span class="text-sm font-normal text-gray-400 dark:text-gray-500 tabular">({allImages.length})</span></h1>
      <div class="flex items-center gap-2">
        <button id="select-all" class="text-xs px-3 py-1.5 rounded-lg border border-gray-300 dark:border-slate-600 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">全选</button>
        <button id="download-zip" data-category={category} data-checkbox-selector=".select-checkbox" class="text-xs px-3 py-1.5 rounded-lg bg-primary-600 text-white hover:bg-primary-700 dark:bg-primary-600 dark:hover:bg-primary-500 transition-colors disabled:opacity-40 disabled:cursor-not-allowed" disabled>打包下载</button>
      </div>
    </div>
    {allImages.length === 0 ? (
      <div class="card p-8 text-center">
        <svg class="w-14 h-14 text-gray-300 dark:text-gray-600 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">暂无图片</p>
        <p class="text-gray-400 dark:text-gray-600 text-xs mt-1">将图片放入 public/images/{category}/ 目录</p>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3" id="gallery-grid">
          {images.map((img, index) => (
            <div class="gallery-item card group relative overflow-hidden cursor-zoom-in" data-index={start + index} data-path={img.path} data-name={img.name} data-fullname={img.fullName}>
              <input type="checkbox" class="select-checkbox absolute top-2 left-2 w-3.5 h-3.5 rounded border-gray-300 dark:border-slate-600 text-primary-600 focus:ring-primary-500 z-10 transition-opacity opacity-60 hover:opacity-100" data-path={img.path} data-name={img.fullName} data-size={img.sizeBytes} />
              <div class="aspect-square overflow-hidden bg-gray-100 dark:bg-slate-700">
                <img src={img.thumbPath} alt={img.meta?.alt || img.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" onerror="this.src=this.dataset.fallback" data-fallback={img.path} />
              </div>
              <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex flex-col justify-end p-3 pointer-events-none">
                <p class="text-white text-xs truncate">{img.name}</p>
                <p class="text-gray-300 text-xs tabular">{img.size}</p>
              </div>
              <button class="open-lightbox absolute top-2 right-2 bg-white/90 p-1.5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity hover:bg-white" data-index={start + index} aria-label="查看大图">
                <svg class="w-3.5 h-3.5 text-gray-800" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.34-4.34"/><line x1="11" y1="8" x2="11" y2="14"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
              </button>
            </div>
          ))}
        </div>
        {totalPages > 1 && (
          <div class="mt-6 flex items-center justify-center gap-2">
            {page > 1 && (
              <a href={'?page=' + (page - 1)} class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 dark:border-slate-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">上一页</a>
            )}
            <span class="text-sm text-gray-400 dark:text-gray-500 tabular px-2">第 {page} / {totalPages} 页</span>
            {page < totalPages && (
              <a href={'?page=' + (page + 1)} class="px-3 py-1.5 text-sm rounded-lg border border-gray-300 dark:border-slate-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors">下一页</a>
            )}
          </div>
        )}
      </>
    )}
    <div class="mt-4">
      <a href="/images" class="inline-flex items-center gap-1.5 text-sm text-gray-500 dark:text-gray-400 link-underline hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        返回
      </a>
    </div>
  </div>
  <div id="lightbox" class="fixed inset-0 bg-black/95 hidden items-center justify-center z-60 select-none" role="dialog" aria-modal="true" aria-label="图片查看器" data-images={JSON.stringify(allImages.map((img) => ({ path: img.path, name: img.name, fullName: img.fullName })))}>
    <button id="lb-close" class="absolute top-4 right-4 text-white/70 hover:text-white p-2 z-10 transition-colors" aria-label="关闭">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
    </button>
    <button id="lb-download" class="absolute top-4 right-14 text-white/70 hover:text-white p-2 z-10 transition-colors" title="下载" aria-label="下载当前图片">
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 15V3"/><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="m7 10 5 5 5-5"/></svg>
    </button>
    <div id="lb-counter" class="absolute top-4 left-1/2 -translate-x-1/2 text-white/80 text-sm font-medium z-10 tabular"></div>
    <button id="lb-prev" class="absolute left-2 md:left-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white p-2 z-10 transition-colors" aria-label="上一张">
      <svg class="w-6 h-6 md:w-8 md:h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
    </button>
    <button id="lb-next" class="absolute right-2 md:right-6 top-1/2 -translate-y-1/2 text-white/60 hover:text-white p-2 z-10 transition-colors" aria-label="下一张">
      <svg class="w-6 h-6 md:w-8 md:h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
    </button>
    <img id="lb-img" src="" alt="" tabindex="-1" class="max-w-[95vw] max-h-[90vh] object-contain transition-opacity duration-200" />
    <div id="lb-caption" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-white/70 text-sm text-center max-w-[90vw] truncate"></div>
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 text-white/30 text-xs flex gap-3"><span>← → 切换</span><span>Esc 关闭</span></div>
  </div>
  <script>// @ts-nocheck
  (function(){
    var g = document.getElementById("gallery-grid");
    if (!g) return;
    var lb = document.getElementById("lightbox"), li = document.getElementById("lb-img"), lc = document.getElementById("lb-caption"),
        lct = document.getElementById("lb-counter"), lcl = document.getElementById("lb-close"), ld = document.getElementById("lb-download"),
        lp = document.getElementById("lb-prev"), ln = document.getElementById("lb-next");
    var allData = JSON.parse(lb.dataset.images);
    var ci = 0;
    function oL(idx) {
      if (!allData.length) return;
      ci = idx; uL();
      lb.classList.remove("hidden"); lb.classList.add("flex");
      document.body.style.overflow = "hidden";
      setTimeout(function() { li.focus(); }, 50);
    }
    function cL() {
      lb.classList.add("hidden"); lb.classList.remove("flex");
      document.body.style.overflow = "";
    }
    function uL() {
      var it = allData[ci];
      li.style.opacity = "0";
      var im = new Image();
      im.onload = function() { li.src = it.path; li.alt = it.name; li.style.opacity = "1"; };
      im.src = it.path;
      lc.textContent = it.name;
      lct.textContent = (ci + 1) + " / " + allData.length;
      ld.onclick = function() {
        var a = document.createElement("a"); a.href = it.path; a.download = it.fullName; a.click();
      };
    }
    function pr() { ci = (ci - 1 + allData.length) % allData.length; uL(); }
    function nx() { ci = (ci + 1) % allData.length; uL(); }
    g.addEventListener("click", function(e) {
      var it = e.target.closest(".gallery-item"), bt = e.target.closest(".open-lightbox");
      if (bt) { e.stopPropagation(); oL(parseInt(bt.dataset.index, 10)); return; }
      if (it && !e.target.closest(".select-checkbox")) { oL(parseInt(it.dataset.index, 10)); }
    });
    lcl.addEventListener("click", cL);
    lp.addEventListener("click", function(e) { e.stopPropagation(); pr(); });
    ln.addEventListener("click", function(e) { e.stopPropagation(); nx(); });
    lb.addEventListener("click", function(e) { if (e.target === lb) cL(); });
    document.addEventListener("keydown", function(e) {
      if (!lb.classList.contains("flex")) return;
      if (e.key === "Escape") cL();
      if (e.key === "ArrowLeft") pr();
      if (e.key === "ArrowRight") nx();
    });
    var tsX = 0, tsY = 0;
    lb.addEventListener("touchstart", function(e) { tsX = e.touches[0].clientX; tsY = e.touches[0].clientY; }, { passive: true });
    lb.addEventListener("touchend", function(e) {
      var dx = e.changedTouches[0].clientX - tsX, dy = e.changedTouches[0].clientY - tsY;
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) { dx > 0 ? pr() : nx(); }
    });
  })();</script>
  <Toast />
  <ZipDownload />
</Layout>
