---
import Layout from '../layouts/Layout.astro';
import { loadIndex } from '../utils/index-loader.js';

let docCount = 0, imgCount = 0;
const ix = loadIndex();
if (ix && ix.files) {
  docCount = ix.files.filter(f => f.type === 'doc').length;
  imgCount = ix.files.filter(f => f.type === 'image').length;
}
---
<Layout title="lycoris">
  <div class="max-w-5xl mx-auto pt-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">lycoris</h1>
      <p class="mt-2 text-gray-500 dark:text-gray-400">文档与图片资源管理站</p>
    </div>
    <div class="grid md:grid-cols-2 gap-4">
      <a href="/docs" class="card card-accent pl-6 pr-5 py-6 flex items-center justify-between group">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 22a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h8a2.4 2.4 0 0 1 1.704.706l3.588 3.588A2.4 2.4 0 0 1 20 8v12a2 2 0 0 1-2 2z"/><path d="M14 2v5a1 1 0 0 0 1 1h5"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          </div>
          <div>
            <h2 class="font-semibold text-gray-900 dark:text-white">文档</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 tabular">{docCount} 个文件</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-primary-500 transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
      <a href="/images" class="card card-accent pl-6 pr-5 py-6 flex items-center justify-between group">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-indigo-600 dark:text-indigo-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
          </div>
          <div>
            <h2 class="font-semibold text-gray-900 dark:text-white">图片</h2>
            <p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5 tabular">{imgCount} 张</p>
          </div>
        </div>
        <svg class="w-5 h-5 text-gray-300 dark:text-gray-600 group-hover:text-primary-500 transition-colors shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    </div>
    <div class="mt-4">
      <a href="/search" class="card px-5 py-4 flex items-center justify-center gap-2 text-sm text-gray-500 dark:text-gray-400 hover:text-primary-600 dark:hover:text-primary-400 group">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m21 21-4.34-4.34"/><circle cx="11" cy="11" r="8"/></svg>
        搜索全部文件
      </a>
    </div>
  </div>
</Layout>
