---
import Layout from '../layouts/Layout.astro';
---
<Layout title="搜索 - 资源站">
  <div class="max-w-4xl mx-auto">
    <div class="mb-4"><h1 class="text-xl font-semibold text-gray-900 dark:text-white">搜索</h1></div>
    <div class="mb-4">
      <div class="relative">
        <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400 dark:text-gray-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <input id="search-input" type="text" placeholder="输入关键词...（按 / 聚焦）" class="w-full pl-9 pr-4 py-2.5 rounded-lg border border-gray-200 dark:border-slate-600 bg-white dark:bg-slate-800 text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent text-sm" autocomplete="off" />
      </div>
    </div>
    <div id="search-stats" class="hidden text-xs text-gray-400 dark:text-gray-500 mb-3 tabular"></div>
    <div id="search-results" class="space-y-3">
      <div class="text-center py-16 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700">
        <svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <p class="text-gray-400 dark:text-gray-500 text-sm">输入关键词开始搜索</p>
      </div>
    </div>
    <div id="loading" class="hidden text-center py-8">
      <div class="inline-block animate-spin rounded-full h-6 w-6 border-4 border-gray-200 dark:border-slate-600 border-t-primary-600"></div>
    </div>
    <div id="pagination" class="hidden mt-4 items-center justify-center gap-2"></div>
  </div>
  <script>(function(){
    var si = document.getElementById("search-input"), sr = document.getElementById("search-results"),
        ss = document.getElementById("search-stats"), lo = document.getElementById("loading"),
        pg = document.getElementById("pagination");
    var idxData = null, dt = null, ar = [], cq = "", PS = 50, cp = 1;
    async function lI() {
      try {
        var r = await fetch("/file-index.json");
        if (!r.ok) throw new Error("HTTP " + r.status);
        idxData = await r.json();
        if (idxData.version && idxData.version !== 1) console.warn("索引版本不兼容:", idxData.version);
        console.log("索引加载完成,共", idxData.files ? idxData.files.length : 0, "个文件");
      } catch (e) {
        console.error("加载索引失败:", e);
        sr.innerHTML = '<div class="text-center py-16 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700"><p class="text-gray-400 dark:text-gray-500 text-sm">索引加载失败，请运行 <code class="bg-gray-100 dark:bg-slate-700 px-1 rounded">npm run index</code></p><p class="text-gray-300 dark:text-gray-600 text-xs mt-1">' + e.message + "</p></div>";
      }
    }
    function eR(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, "\\$&"); }
    function eH(s){if(!s)return"";return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;").replace(/'/g,"&#39;");}
    function hl(t, q) {
      if (!t || !q) return eH(t);
      var re = new RegExp("(" + eR(q) + ")", "gi");
      return t.split(re).map(function(p, i) {
        return i % 2 === 1 ? '<mark class="bg-primary-100 dark:bg-primary-900/40 text-primary-700 dark:text-primary-300 rounded px-0.5">' + eH(p) + "</mark>" : eH(p);
      }).join("");
    }
    function gC(t, q, r) {
      r = r || 60;
      if (!t || !q) return "";
      var i = t.toLowerCase().indexOf(q.toLowerCase());
      if (i === -1) return t.substring(0, 150);
      var s = Math.max(0, i - r), e = Math.min(t.length, i + q.length + r), sn = t.substring(s, e);
      if (s > 0) sn = "..." + sn;
      if (e < t.length) sn += "...";
      return sn;
    }
    function sQ(q) {
      if (!idxData || !q.trim()) { sE(); return; }
      var ql = q.toLowerCase().trim(); cq = ql; cp = 1; ar = [];
      for (var i = 0; i < idxData.files.length; i++) {
        var f = idxData.files[i], sc = 0;
        if (f.name.toLowerCase().includes(ql)) sc += 100;
        if (f.category.toLowerCase().includes(ql)) sc += 50;
        if (f.fullText && f.fullText.toLowerCase().includes(ql)) {
          sc += 30;
          var re = new RegExp(eR(ql), "gi"), mc = f.fullText.match(re);
          if (mc) sc += mc.length * 2;
        }
        if (sc > 0) ar.push(Object.assign({}, f, { score: sc }));
      }
      ar.sort(function(a, b) { return b.score - a.score; });
      rP(1);
    }
    function rP(p) {
      cp = p;
      var t = ar.length, tp = Math.ceil(t / PS), st = (p - 1) * PS, prr = ar.slice(st, st + PS);
      ss.classList.remove("hidden");
      ss.textContent = "共 " + t + " 个结果" + (tp > 1 ? "（第 " + p + "/" + tp + " 页）" : "");
      if (prr.length === 0) { sN(cq); pg.classList.add("hidden"); return; }
      sr.innerHTML = prr.map(function(f) {
        var iD = f.type === "doc", ic = iD ?
          '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>' :
          '<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>';
        var bg = "bg-gray-100 dark:bg-slate-700 text-gray-600 dark:text-gray-300";
        var pp = f.fullText ? '<p class="text-xs text-gray-400 dark:text-gray-500 mt-1.5 line-clamp-2">' + hl(gC(f.fullText, cq), cq) + "</p>" : "";
        return '<a href="' + f.path + '" target="_blank" rel="noopener noreferrer" class="block bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700 p-3.5 hover:border-primary-500 dark:hover:border-primary-500 hover:shadow-sm transition-all"><div class="flex items-start gap-3"><div class="shrink-0 w-8 h-8 rounded-lg ' + bg + ' flex items-center justify-center">' + ic + '</div><div class="flex-1 min-w-0"><h3 class="text-sm font-medium text-gray-900 dark:text-white truncate">' + eH(f.name) + '</h3><p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5 tabular">' + eH(f.category) + " · " + f.size + "</p>" + pp + '</div><div class="shrink-0 text-xs text-gray-300 dark:text-gray-600 uppercase">' + f.ext + "</div></div></a>";
      }).join("");
      if (tp > 1) {
        pg.classList.remove("hidden"); pg.classList.add("flex");
        var ph = "";
        if (p > 1) ph += '<button class="page-btn px-3 py-1 text-sm rounded-md border border-gray-300 dark:border-slate-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700" data-page="' + (p - 1) + '">上一页</button>';
        var mV = 5, ps = Math.max(1, p - Math.floor(mV / 2)), pe = Math.min(tp, ps + mV - 1);
        if (pe - ps < mV - 1) ps = Math.max(1, pe - mV + 1);
        if (ps > 1) ph += '<span class="px-2 text-gray-400 dark:text-gray-600">...</span>';
        for (var i = ps; i <= pe; i++) {
          ph += '<button class="page-btn px-3 py-1 text-sm rounded-md ' + (i === p ? "bg-primary-600 text-white" : "border border-gray-300 dark:border-slate-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700") + '" data-page="' + i + '">' + i + "</button>";
        }
        if (pe < tp) ph += '<span class="px-2 text-gray-400 dark:text-gray-600">...</span>';
        if (p < tp) ph += '<button class="page-btn px-3 py-1 text-sm rounded-md border border-gray-300 dark:border-slate-600 text-gray-600 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-slate-700" data-page="' + (p + 1) + '">下一页</button>';
        pg.innerHTML = ph;
        pg.querySelectorAll(".page-btn").forEach(function(b) {
          b.addEventListener("click", function() {
            var np = parseInt(b.dataset.page, 10);
            rP(np);
            sr.scrollIntoView({ behavior: "smooth" });
          });
        });
      } else {
        pg.classList.remove("flex"); pg.classList.add("hidden");
      }
    }
    function sE() {
      sr.innerHTML = '<div class="text-center py-16 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700"><svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg><p class="text-gray-400 dark:text-gray-500 text-sm">输入关键词开始搜索</p></div>';
      ss.classList.add("hidden");
      pg.classList.add("hidden");
    }
    function sN(q) {
      sr.innerHTML = '<div class="text-center py-16 bg-white dark:bg-slate-800 rounded-lg border border-gray-200 dark:border-slate-700"><svg class="w-12 h-12 text-gray-300 dark:text-gray-600 mx-auto mb-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg><p class="text-gray-400 dark:text-gray-500 text-sm">未找到与 "' + eH(q) + '" 相关的结果</p></div>';
    }
    si.addEventListener("input", function() {
      clearTimeout(dt);
      lo.classList.remove("hidden");
      sr.classList.add("opacity-50");
      dt = setTimeout(function() {
        sQ(si.value);
        lo.classList.add("hidden");
        sr.classList.remove("opacity-50");
      }, 300);
    });
    document.addEventListener("keydown", function(e) {
      var tag = document.activeElement?.tagName;
      var isInput = /^(INPUT|TEXTAREA|SELECT)$/.test(tag) || document.activeElement?.isContentEditable;
      if (e.key === "/" && !isInput) { e.preventDefault(); si.focus(); }
      if (e.key === "Escape" && document.activeElement === si) { si.blur(); }
    });
    lI();
  })();</script>
</Layout>
